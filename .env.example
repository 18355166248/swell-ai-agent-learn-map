# ============================================================
# 环境变量说明
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================================

# --- Anthropic 兼容 API（projects/01-ai-code-explain/cli.ts 使用） ---
# analyzer.ts 优先读取此变量，缺失时回退到 OPENAI_API_KEY
ANTHROPIC_API_KEY=your-anthropic-api-key
# 必须填写 Anthropic/deepgate 兼容网关地址；这里不会自动修正路径
ANTHROPIC_BASE_URL=

# --- OpenAI / OpenRouter 兼容 API（cli-openai.ts 使用） ---
# analyzer-openai.ts 直接读取此变量
OPENAI_API_KEY=your-openai-api-key

# --- 自定义 API 地址（OpenAI CLI 使用，可选） ---
# OpenAI SDK: 设为 OpenRouter 或兼容服务地址，如 https://openrouter.ai/api/v1
# 不设则使用 cli-openai.ts 的默认地址 https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# --- 模型名称（可选） ---
# cli.ts (Anthropic) 默认: official-deepseek-v4-pro
# cli-openai.ts (OpenAI) 默认: openai/gpt-oss-120b:free
MODEL_NAME=

# --- Embedding 模型（默认 text-embedding-3-small）---
EMBEDDING_MODEL=text-embedding-3-small

# --- 本地存储路径 ---
VECTOR_STORE_PATH=./.data/vectors.json
DOCS_PATH=./docs/knowledge-base
